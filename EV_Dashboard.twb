      </column>
      <column caption='Total Vehicles' datatype='integer' name='[Calculation_0890916236951552]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([DOL Vehicle ID])' />
      </column>
      <column caption='Avg Electric Range' datatype='real' name='[Calculation_0890916238036993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Electric Range])' />
      </column>
      <column caption='Total BEV Vehicles' datatype='integer' name='[Calculation_0890916239933442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Electric Vehicle Type]=&quot;Battery Electric Vehicle (BEV)&quot; &#13;&#10;THEN [DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% of BEV Vehicles' datatype='real' name='[Calculation_0890916240859139]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0890916239933442]/[Calculation_0890916236951552]' />
      </column>
      <column caption='Total PHEV Vehicles' datatype='integer' name='[Calculation_0890916242288644]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF [Electric Vehicle Type] = &quot;Plug-in Hybrid Electric Vehicle (PHEV)&quot;&#13;&#10;THEN&#13;&#10;[DOL Vehicle ID]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='% of PHEV Vehicles' datatype='real' name='[Calculation_0890916245528582]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0890916242288644]/[Calculation_0890916236951552]' />
      </column>
