      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.15ht3os1r5m5151a04to40dx3r6q].[pcto:usr:Calculation_0890916236951552:qk]&quot;' value='% of Total' />
